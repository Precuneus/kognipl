<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('tmSlider');
    const current = document.getElementById('tmCurrent');
    const stops = document.querySelectorAll('.tm-stop');
    const sessionEls = document.querySelectorAll('[data-session]');

    const sessionNames = {
      1: 'Ewolucja',
      2: 'Rozwój poznawczy'
    };

    function updateTimeMachine(val) {
      const v = parseInt(val);
      const vcenter = window.innerHeight / 2;

      // Find permanent element CLOSEST to viewport center
      const permanents = document.querySelectorAll('.course-page h2:not(.s2), .course-page h3:not(.s2), .course-page p:not(.s2), .course-page .formula-box, .course-page .video-label, .course-page .cascade-step, .course-page .niche-card, .course-page hr.section-divider');
      let anchorEl = null;
      let anchorTop = 0;
      let best = Infinity;

      for (const el of permanents) {
        if (el.closest('.s2')) continue;
        if (el.parentElement && el.parentElement.classList.contains('s2')) continue;
        if (!el.offsetHeight) continue;
        const r = el.getBoundingClientRect();
        const d = Math.abs(r.top + r.height / 2 - vcenter);
        if (d < best) {
          best = d;
          anchorEl = el;
          anchorTop = r.top;
        }
      }

      stops.forEach(s => {
        s.classList.toggle('active', parseInt(s.dataset.s) <= v);
      });
      current.textContent = 'Pokazuję stronę po sesji ' + v + ': ' + (sessionNames[v] || '');

      sessionEls.forEach(el => {
        el.classList.toggle('hidden', parseInt(el.dataset.session) > v);
      });

      if (anchorEl) {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const drift = anchorEl.getBoundingClientRect().top - anchorTop;
            if (Math.abs(drift) > 1) {
              const s = document.documentElement.style;
              const prev = s.scrollBehavior;
              s.scrollBehavior = 'auto';
              window.scrollBy(0, drift);
              s.scrollBehavior = prev;
            }
          });
        });
      }
    }

    if (slider) {
      slider.addEventListener('input', (e) => updateTimeMachine(e.target.value));
      updateTimeMachine(slider.value);

      // iOS Safari fix: prevent page scroll when touching the slider
      const tmContainer = document.querySelector('.time-machine');
      tmContainer.addEventListener('touchmove', (e) => {
        if (e.target === slider || e.target.closest('.time-machine-inner')) {
          e.preventDefault();
        }
      }, { passive: false });
    }
  });
</script>

