        <div class="session-row" style="color: color-mix(in srgb, var(--text-secondary) 70%, #7a6bbf 30%)"><span class="s-key">s11</span> Reprezentacjonizm a percepcja bezpośrednia</div>
      </div>
    </div>
  </aside>

  </div> <!-- /.course-layout -->
</PasswordGate>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ── YouTube lazy-load facades ──
    document.querySelectorAll('.video-wrapper iframe').forEach(iframe => {
      const src = iframe.getAttribute('src');
      if (!src || !src.includes('youtube.com/embed/')) return;

      const urlParts = src.split('?');
      const videoId = urlParts[0].split('/embed/')[1];
      const existingParams = urlParts[1] || '';

      const facade = document.createElement('div');
      facade.className = 'yt-facade';
      facade.dataset.src = src;
      facade.dataset.title = iframe.title || '';

      const thumb = document.createElement('img');
      thumb.src = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
      thumb.alt = iframe.title || 'YouTube video';
      thumb.loading = 'lazy';

      const btn = document.createElement('div');
      btn.className = 'yt-play-btn';
      btn.innerHTML = '<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';

      facade.appendChild(thumb);
      facade.appendChild(btn);

      facade.addEventListener('click', () => {
        const base = urlParts[0];
        const newSrc = existingParams
          ? `${base}?autoplay=1&${existingParams}`
          : `${base}?autoplay=1`;

        const newIframe = document.createElement('iframe');
        newIframe.src = newSrc;
        newIframe.title = facade.dataset.title;
        newIframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        newIframe.allowFullscreen = true;
        newIframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:none;';

        const wrapper = facade.parentElement;
        wrapper.classList.add('playing');
        wrapper.removeChild(facade);
        wrapper.appendChild(newIframe);
      });

      const wrapper = iframe.parentElement;
      wrapper.removeChild(iframe);
      wrapper.appendChild(facade);
    });

    // ── Session checkboxes ──
    const checkboxes = document.querySelectorAll('.tm-check input[type="checkbox"]');
    const sessionEls = document.querySelectorAll('[data-session]');

    // S01 content: elements inside .course-page that have no data-session
    // and are not structural (h2, hr, time-machine, back-link, h1, meta, sidebar)
    const coursePage = document.querySelector('.course-page');
    const s1ContentSelectors = 'p, h3, ul, ol, .formula-box, .video-block, .video-grid, .video-grid-solo, .video-grid-label, .network-cascade, .niche-cards, .tract-list, .debate-grid, figure, table, .figure-block';

    function getS1Elements() {
      const candidates = coursePage.querySelectorAll(s1ContentSelectors);
      return Array.from(candidates).filter(el => {
        if (el.dataset.session) return false;
        if (el.closest('[data-session]')) return false;
        if (el.closest('.time-machine')) return false;
        if (el.closest('.questions-section')) return false;
        if (el.closest('.kolokwium-box')) return false;
        if (el.classList.contains('meta')) return false;
        return true;
      });
    }

    function getCheckedSessions() {
      const checked = new Set();
      checkboxes.forEach(cb => {
        if (cb.checked) checked.add(parseInt(cb.dataset.s));
      });
      return checked;
    }

    function updateSessionVisibility() {
      const checked = getCheckedSessions();

      // Scroll anchor: find first visible element that will survive the toggle
      const headerH = 80;
      let anchorEl = null;
      let anchorTop = 0;

      const sel = window.getSelection();
      if (sel && sel.rangeCount > 0 && !sel.isCollapsed) {
        let node = sel.getRangeAt(0).startContainer;
        if (node.nodeType === 3) node = node.parentElement;
        const candidate = node.closest('p, h2, h3, li, .formula-box, .cascade-step, .niche-card, .figure-block');
        if (candidate && candidate.offsetHeight) {
          anchorEl = candidate;
          anchorTop = candidate.getBoundingClientRect().top;
        }
      }

      if (!anchorEl) {
        const allContent = coursePage.querySelectorAll('h2, h3, p, .formula-box, .video-label, .cascade-step, .niche-card, hr.section-divider, .figure-block, .video-block');
        let best = Infinity;
        for (const el of allContent) {
          if (!el.offsetHeight) continue;
          const r = el.getBoundingClientRect();
          if (r.bottom < headerH) continue;
          const d = Math.max(r.top, headerH) - headerH;
          if (d < best) { best = d; anchorEl = el; anchorTop = r.top; }
        }
      }

      // Toggle S2-S8 content
      sessionEls.forEach(el => {
        const s = parseInt(el.dataset.session);
        if (s >= 1) {
          el.classList.toggle('hidden', !checked.has(s));
        }
      });

      // Toggle S1 content (elements without data-session)
      const s1Els = getS1Elements();
      const s1Hidden = !checked.has(1);
      s1Els.forEach(el => {
        el.classList.toggle('hidden', s1Hidden);
      });

      // Sync nav sidebar
      if (typeof updateNavVisibility === 'function') updateNavVisibility();

      // Restore scroll position
      if (anchorEl) {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const drift = anchorEl.getBoundingClientRect().top - anchorTop;
            if (Math.abs(drift) > 1) {
              const s = document.documentElement.style;
              const prev = s.scrollBehavior;
              s.scrollBehavior = 'auto';
              window.scrollBy(0, drift);
              s.scrollBehavior = prev;
            }
          });
        });
      }
    }

    // Master toggle: check/uncheck all session boxes at once
    const allToggle = document.getElementById('tm-all-toggle');

    function syncAllToggle() {
      if (!allToggle) return;
      const total = checkboxes.length;
      let on = 0;
      checkboxes.forEach(cb => { if (cb.checked) on++; });
      allToggle.checked = on === total;
      allToggle.indeterminate = on > 0 && on < total;
    }

    if (allToggle) {
      allToggle.addEventListener('change', () => {
        const turnOn = allToggle.checked;
        checkboxes.forEach(cb => { cb.checked = turnOn; });
        allToggle.indeterminate = false;
        updateSessionVisibility();
      });
    }

    checkboxes.forEach(cb => {
      cb.addEventListener('change', () => { updateSessionVisibility(); syncAllToggle(); });
    });

    updateSessionVisibility();
    syncAllToggle();

    // ── Section navigator: scroll tracking ──
    const navLinks = document.querySelectorAll('.nav-sidebar a[data-nav]');
    const sectionIds = ['sec-perspektywy','sub-perspektywy','sub-model','sec-zasady','sub-predykcja','sub-informacja','sec-architektura','sub-sieci','sub-nisze','sec-daleko','sub-dmn','sub-hipokamp','sub-pamiec','sub-sen','sub-pojecia','sub-myslenie','sub-spoleczny','sub-teoria-umyslu','sec-blisko','sub-afordancje','sub-4e','sec-uczenie','sub-stadia','sub-przywiazanie','sub-dopamina','sub-przyczyny','sub-przejecie','sub-serotonina','sec-jezyk','sub-jezyk','sub-afazja','sub-jezyk-myslenie','sec-salience','sub-lancuch','sub-emocje','sub-afekt','sub-sm','sub-koregulacja','sub-granulacja','sec-wnioski','sec-pytania'];
    const allNavEls = sectionIds.map(id => document.getElementById(id)).filter(Boolean);
    let currentNav = '';
    let currentSection = '';

    function updateNavHighlight() {
      const scrollY = window.scrollY + 120;
      let active = '';
      let activeSection = '';
      for (const el of allNavEls) {
        if (el.offsetParent !== null && el.offsetTop <= scrollY) {
          active = el.id;
          if (sectionIds.includes(el.id)) activeSection = el.id;
        }
      }
      if (active !== currentNav) {
        currentNav = active;
        navLinks.forEach(link => {
          link.classList.toggle('active', link.dataset.nav === active);
        });
      }
      if (activeSection !== currentSection) {
        currentSection = activeSection;
        updateGlossary(activeSection);
      }
    }

    // ── Glossary: context-sensitive visibility ──
    const glossaryEntries = document.querySelectorAll('.glossary-entry');

    function updateGlossary(sectionId) {
      glossaryEntries.forEach(entry => {
        const sections = entry.dataset.sections || '';
        const relevant = !sectionId || sections.includes(sectionId);
        entry.classList.toggle('hidden', !relevant);
      });
    }

    // ── Nav links: hide session-gated sections when their checkbox is off ──
    function updateNavVisibility() {
      const checked = getCheckedSessions();
      navLinks.forEach(link => {
        const sess = link.dataset.session;
        if (sess) {
          link.style.display = checked.has(parseInt(sess)) ? '' : 'none';
        }
      });
    }

    // Throttled scroll listener
    let scrollTick = false;
    window.addEventListener('scroll', () => {
      if (!scrollTick) {
        scrollTick = true;
        requestAnimationFrame(() => {
          updateNavHighlight();
          scrollTick = false;
        });
      }
    });

    // Smooth scroll for nav links
    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(link.dataset.nav);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Initialize
    updateNavHighlight();
    updateNavVisibility();
  });
</script>

</Base>