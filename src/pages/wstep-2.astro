---
import Base from '../layouts/Base.astro';
import PasswordGate from '../components/PasswordGate.astro';

const HASH = "f4af56884306e3a5bc827f87770f843ec80be636fba15386e940a64d99d29a63";
---
<Base title="Wstęp do kognitywistyki II - kogni.pl" activePage="kursy">

<style is:global>
  .course-page { max-width: 720px; margin: 0 auto; padding: 48px 24px 140px; }

  .back-link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.3s;
  }
  .back-link:hover { color: var(--warm-glow); }

  .course-page h1 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: 2px;
    margin-bottom: 8px;
    text-align: center;
  }
  .course-page .meta {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    text-align: center;
    letter-spacing: 1px;
    margin-bottom: 48px;
  }

  .session-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--warm-glow);
    border: 1px solid var(--warm-glow);
    padding: 4px 12px;
    margin-bottom: 20px;
  }
  .session-header { text-align: center; margin-bottom: 48px; }
  .session-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: 1px;
    margin-bottom: 8px;
    margin-top: 12px;
  }
  .session-subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .course-page h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 48px 0 16px;
    letter-spacing: 0.5px;
  }
  .course-page h3 {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 32px 0 12px;
    letter-spacing: 0.3px;
  }

  .course-page p {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.85;
    margin-bottom: 16px;
  }
  .course-page strong { font-weight: 500; color: var(--text-primary); }
  .course-page em { font-style: italic; }
  .course-page ul { padding-left: 20px; margin: 12px 0 16px; }
  .course-page li {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 8px;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 40px 0;
  }

  /* ── Formula box (centered, prominent) ── */
  .formula-box {
    background: var(--warm-glow-soft);
    border: 1px solid var(--border-warm);
    padding: 20px 28px;
    margin: 28px auto;
    text-align: center;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 1px;
    max-width: 420px;
  }

  /* ── Network cascade ── */
  .network-cascade { margin: 20px 0 28px; }
  .cascade-step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .cascade-step:last-child { border-bottom: none; }
  .cascade-num {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--warm-glow);
    min-width: 32px;
    padding-top: 2px;
    flex-shrink: 0;
  }
  .cascade-content { flex: 1; }
  .cascade-name {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 3px;
  }
  .cascade-abbr {
    font-weight: 300;
    color: var(--text-dim);
    font-size: 11px;
    letter-spacing: 0.5px;
    margin-left: 6px;
  }
  .cascade-desc {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── Niche cards ── */
  .niche-cards { display: flex; flex-direction: column; gap: 10px; margin: 20px 0 24px; }
  .niche-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--warm-glow);
    padding: 14px 18px;
  }
  .niche-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--warm-glow);
    margin-bottom: 5px;
  }
  .niche-card p {
    font-size: 13px;
    margin-bottom: 0;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .niche-card strong { font-weight: 500; color: var(--text-primary); }

  /* ── Debate columns ── */
  .debate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 20px 0 24px;
  }
  @media (max-width: 560px) { .debate-grid { grid-template-columns: 1fr; } }
  .debate-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    padding: 18px;
  }
  .debate-card.continuity { border-top: 2px solid var(--warm-glow); }
  .debate-card.uniqueness { border-top: 2px solid rgba(150, 150, 210, 0.5); }
  .debate-side {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 4px;
  }
  .debate-author {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 12px;
    line-height: 1.4;
  }
  .debate-card ul { padding-left: 14px; margin: 0; }
  .debate-card li {
    font-size: 13px;
    line-height: 1.65;
    margin-bottom: 7px;
    color: var(--text-secondary);
  }
  .debate-card p { font-size: 13px; margin-bottom: 0; line-height: 1.7; color: var(--text-secondary); }
  .debate-card strong { font-weight: 500; color: var(--text-primary); }

  /* ── Language tracts ── */
  .tract-list { margin: 16px 0 20px; }
  .tract-row {
    display: flex;
    gap: 12px;
    align-items: baseline;
    padding: 9px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .tract-row:last-child { border-bottom: none; }
  .tract-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--warm-glow);
    min-width: 88px;
    flex-shrink: 0;
  }
  .tract-path {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-secondary);
    letter-spacing: 0.2px;
  }
  .tract-path .arrow { color: var(--text-dim); margin: 0 3px; }

  /* ── Figure ── */
  .figure-block {
    margin: 28px 0 32px;
    border: 1px solid var(--border-subtle);
    background: var(--bg-card);
    padding: 16px;
  }
  .figure-block img {
    width: 100%;
    display: block;
  }
  .figure-block figcaption {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    line-height: 1.6;
    margin-top: 10px;
    font-style: italic;
  }

  /* ── Table ── */
  .course-page table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-family: var(--font-body);
    font-size: 13px;
  }
  .course-page th {
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 11px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-warm);
    text-align: left;
  }
  .course-page td {
    padding: 10px 14px;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
    line-height: 1.6;
  }
  .course-page tr:last-child td { border-bottom: none; }
  .level-tag {
    font-size: 11px;
    font-weight: 500;
    color: var(--warm-glow);
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  /* ── Single video ── */
  .video-block { margin: 36px 0; }
  .video-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .video-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: rgba(0,0,0,0.3);
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
  }
  .video-caption {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    margin-top: 8px;
    font-style: italic;
  }

  /* ── Video grid (senses) ── */
  .video-grid-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 32px 0 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .video-grid-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }
  .video-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 8px; }
  .video-grid-item { display: block; }
  .video-grid-solo { max-width: 50%; margin: 12px 0 0; }
  @media (max-width: 560px) {
    .video-grid { grid-template-columns: 1fr; }
    .video-grid-solo { max-width: 100%; }
  }

  /* ── Questions ── */
  .question-list { margin: 0; padding: 0; list-style: none; }
  .question-list li {
    display: flex;
    gap: 20px;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.65;
  }
  .question-list li:first-child { border-top: 1px solid var(--border-subtle); }
  .question-num {
    font-size: 11px;
    font-weight: 500;
    color: var(--warm-glow);
    letter-spacing: 1px;
    min-width: 24px;
    flex-shrink: 0;
    padding-top: 1px;
  }

  /* ── Bibliography ── */
  .bibliography { margin-top: 48px; }
  .bib-item {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 12px;
    padding-left: 20px;
    text-indent: -20px;
  }
  .bib-item a {
    color: var(--warm-glow);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .bib-item a:hover { opacity: 1; }
  .bib-item em { font-style: italic; }

  /* ── Act navigation ── */
  .act-nav {
    display: flex;
    justify-content: center;
    gap: 0;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--border-subtle);
    overflow-x: auto;
  }
  .act-tab {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 12px 20px 10px;
    border: none;
    background: none;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color 0.3s, border-color 0.3s;
    opacity: 0.45;
  }
  .act-tab.active {
    color: var(--warm-glow);
    border-bottom-color: var(--warm-glow);
    opacity: 1;
  }
  .act-tab.upcoming {
    cursor: default;
    opacity: 0.25;
  }
  .act-tab:not(.upcoming):hover {
    color: var(--warm-glow);
    opacity: 0.8;
  }

  /* ── Time machine slider ── */
  .time-machine {
    background: var(--bg-card);
    border-top: 1px solid var(--border-subtle);
    padding: 12px 0 16px;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg-card) 85%, transparent);
    box-shadow: 0 -2px 12px rgba(0,0,0,0.08);
    overflow: hidden;
  }
  .time-machine-inner {
    max-width: 672px;
    margin: 0 auto;
    padding: 0 24px;
    box-sizing: border-box;
    touch-action: none;
    -ms-touch-action: none;
  }
  .tm-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 10px;
  }
  .tm-slider {
    width: 100%;
    max-width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 3px;
    background: var(--border-subtle);
    outline: none;
    border-radius: 2px;
    cursor: pointer;
    touch-action: none;
    -ms-touch-action: none;
    box-sizing: border-box;
    display: block;
    padding: 14px 0;
    margin: -14px 0;
    background-clip: content-box;
  }
  @media (max-width: 560px) {
    .time-machine-inner {
      padding: 0 32px;
    }
  }
  .tm-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--warm-glow);
    cursor: pointer;
    border: 2px solid var(--bg-card);
    box-shadow: 0 0 0 1px var(--warm-glow);
  }
  .tm-slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--warm-glow);
    cursor: pointer;
    border: 2px solid var(--bg-card);
    box-shadow: 0 0 0 1px var(--warm-glow);
  }
  .tm-stops {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
  }
  .tm-stop {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 300;
    color: var(--text-dim);
    transition: color 0.3s, font-weight 0.3s;
  }
  .tm-stop.active {
    color: var(--warm-glow);
    font-weight: 500;
  }
  .tm-current {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    color: var(--text-secondary);
    margin-top: 6px;
    text-align: center;
    min-height: 18px;
  }

  /* ── Session additions: inline spans + standalone blocks ── */
  .s2 {
    transition: opacity 0.4s ease;
  }
  /* Block-level s2 elements */
  p.s2, li.s2 {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c8956c 30%);
  }
  p.s2 strong, li.s2 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c8956c 30%);
  }
  h3.s2 {
    color: color-mix(in srgb, var(--text-primary) 75%, #c8956c 25%);
  }
  p.s2 em {
    color: color-mix(in srgb, var(--text-dim) 70%, #c8956c 30%);
  }
  /* Inline s2 spans within existing paragraphs */
  span.s2 {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c8956c 30%);
  }
  span.s2 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c8956c 30%);
  }
  /* Legacy div.s2 support (for blocks that remain) */
  div.s2 p, div.s2 li, div.s2 .cascade-desc, div.s2 .niche-card p {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c8956c 30%);
  }
  div.s2 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c8956c 30%);
  }
  div.s2 h3 {
    color: color-mix(in srgb, var(--text-primary) 75%, #c8956c 25%);
  }
  .s2.hidden {
    display: none;
  }

</style>

<PasswordGate
  title="Wstęp do kognitywistyki II"
  subtitle="Semestr letni 2025/2026"
  passwordHash={HASH}
  sessionKey="wstep-2"
>
  <div class="course-page">
    <a href="/kursy" class="back-link">&larr; Kursy</a>
    <h1>Wstęp do kognitywistyki II</h1>
    <p class="meta">ćwiczenia · I rok · semestr letni 2025/2026 · 30h</p>

    <!-- ==================== ACT NAVIGATION ==================== -->
    <nav class="act-nav">
      <button class="act-tab active" data-act="1">Skąd się wzięliśmy?</button>
      <button class="act-tab upcoming">Co się dzieje w środku?</button>
      <button class="act-tab upcoming">Gdzie są granice?</button>
    </nav>

    <!-- ==================== TIME MACHINE (fixed bottom) ==================== -->
    <div class="time-machine">
      <div class="time-machine-inner">
        <div class="tm-label">Oś czasu kursu</div>
        <input type="range" class="tm-slider" id="tmSlider" min="1" max="2" value="2" step="1" />
        <div class="tm-stops">
          <span class="tm-stop active" data-s="1">Ewolucja</span>
          <span class="tm-stop active" data-s="2">Rozwój</span>
        </div>
        <div class="tm-current" id="tmCurrent">Pokazuję stronę po sesji 2: Rozwój poznawczy</div>
      </div>
    </div>

    <div class="session-header">
      <div class="session-title">Skąd się wzięliśmy?</div>
      <div class="session-subtitle">Ewolucja · Rozwój · Predykcje · Afordancje</div>
    </div>

    <!-- ==================== PODSTAWOWE POJĘCIA ==================== -->
    <h2>Podstawowe pojęcia</h2>

    <h3>Mózg i doświadczenie</h3>
    <p>Czytasz płynnie te słowa dzięki dekadom treningu swoich sieci neuronowych. Gdyby ktoś skanował Ci mózg, widziałby wzorce aktywności elektrycznej, przepływ krwi, sygnały BOLD w fMRI. Z boku widać Twoje oczy poruszające się wzdłuż tekstu, wyraz twarzy, może skinienie głową. Od środka... po prostu czytasz. Doświadczasz znaczenia tekstu.</p>
    <p>Dwie perspektywy: od wewnątrz i z zewnątrz. Od tego zaczynamy ten kurs.</p>

    <hr class="section-divider" />

    <h3>Model</h3>
    <p>Doświadczana "rzeczywistość" to model powstały w wyniku wielu lat treningu Twoich biologicznych sieci neuronowych. Doświadczasz modelu generowanego przez aktywność swoich sieci mózgowych. Treść doświadczenia to model. Uszkodzenie zakrętu wrzecionowatego wykasuje twarze z treści Twojego doświadczenia; uszkodzenie V5/MT sprawi, że odświeżanie rzeczywistości zwolni do kilku klatek na sekundę; uszkodzenie prawej kory ciemieniowej tymczasowo wymaże lewą stronę doświadczenia.</p>
    <p>Model powstał podczas lat treningu. <span class="s2" data-session="2">Joscha Bach zauważa, że Genesis to nie opis stworzenia świata. To opis stworzenia świata przez każde dziecko. Rodzisz się w ciemność. Potem jest światło: kora wzrokowa oddziela figurę od tła. Potem formy oddzielają się od siebie. Potem obiekty zyskują stałość. Potem pojawiają się istoty żywe. Na końcu je nazywasz. Każde dziecko wykonuje Genesis. Buduje swój świat od zera, z korelacji między zmysłami. Piaget opisał te kroki jako stadia rozwoju:</span> Wiesz, czym skutkuje zaburzenie treningu podczas okresów krytycznych.</p>
    <p class="s2" data-session="2"><strong>Sensoryczno-motoryczne (0-2 lata):</strong> świat jest czystym doznaniem. Dotyk, smak, ruch. Chwytasz, wkładasz do ust, rzucasz. Powoli odkrywasz, że rzeczy istnieją nawet gdy na nie nie patrzysz. Twój pierwszy model: świat trwa. Twoja pierwsza predykcja.</p>
    <p class="s2" data-session="2"><strong>Przedoperacyjne (2-7 lat):</strong> pojawiają się symbole. Słowa. Zabawa "na niby." Ale jesteś sam w swoim świecie: nie potrafisz jeszcze zbudować modelu tego, jak ktoś inny widzi tę samą sytuację. Twój Genesis jest jednoosobowy.</p>
    <p class="s2" data-session="2"><strong>Operacji konkretnych (7-11 lat):</strong> Twój świat zyskuje reguły. Przyczyny prowadzą do skutków. Afordancje stają się przewidywalne: wiesz, co się stanie, gdy coś zrobisz. Ale tylko z tym, co masz przed sobą.</p>
    <p class="s2" data-session="2"><strong>Operacji formalnych (11+ lat):</strong> możesz przewidywać rzeczy, które nie istnieją. Hipotetyczne scenariusze. Kontrfaktyczne rozumowanie. Słowo "jutro." Słowo "sprawiedliwość." Twój świat rozszerza się poza to, co widzisz i dotykasz.</p>
    <p class="s2" data-session="2">Dwa mechanizmy napędzają stworzenie. <strong>Asymilacja:</strong> nowe doświadczenie pasuje do istniejącego modelu. Mały błąd predykcyjny, model się aktualizuje. <strong>Akomodacja:</strong> doświadczenie jest zbyt zaskakujące. Duży błąd predykcyjny, potrzebny nowy schemat. Piłka okrągła toczy się prosto. Piłka do rugby nie. Schemat "piłki" wymaga przebudowy. Alison Gopnik proponuje, że dzieci to zoptymalizowane maszyny do eksploracji: testują więcej hipotez, akceptują więcej błędów, próbują więcej wariantów. Dorośli eksploatują wyuczone modele. Dzieci eksplorują. Wysoka temperatura w języku sieci neuronowych.</p>
    <p>"Ty" też jesteś modelem. Jesteś historią swoich wcześniejszych doświadczeń, opowieścią, jaką kultywujesz w swojej spójnej narracji tłumaczącej Twoje życie. Jak myślisz o sobie, jak się zmieniasz, czy masz jedno czy wiele żyć? Możliwe, że jesteś pomocną i życzliwą osobą, ale uszkodzenie mózgu może sprawić, że zmienisz się diametralnie, jak Phineas Gage. W innych przypadkach tożsamość może zniknąć całkiem - demencja uniemożliwia tworzenie spójnej narracji o sobie i zapamiętywanie swojej historii. "Ty" to też model.</p>
    <p>Jedyne co zostaje, to interakcja między "Ty" a "rzeczywistością". Między Twoją perspektywą a treścią. Na tym styku jest doświadczanie. To wydaje się najbardziej prawdziwe, uniwersalne. Ale niebezpiecznie oddala się w kierunku filozofii.</p>
    <p>Wróćmy do modeli. Modele są predyktywne. <span class="s2" data-session="2">Jak przebiega to stworzenie z chwili na chwilę?</span></p>

    <hr class="section-divider" />

    <h3>Predykcja</h3>
    <p>Sieci neuronowe nie czekają na informacje ze świata, żeby potem zareagować. Sieci cały czas aktywnie przewidują przyszłe informacje. Są jak surferzy pokonujący fale - muszą przewidywać, co będzie za chwilę.</p>
    <p>Prowadzisz samochód na autostradzie. Zmieniasz pasy, wyprzedzasz, jedziesz płynnie. Mimo prędkości wszystko jest... przewidywalne. Sterujesz swoim samochodem, wiesz, jak zareaguje na naciśnięcie pedałów, skręt kierownicy - Twoje sieci mózgowe są już wytrenowane. Nie to co na początku! Wtedy przecież nawet płynne ruszenie było wyzwaniem.</p>
    <p>To jest predykcja: nieustanne generowanie hipotez o tym, co zaraz nastąpi. Percepcja nie jest rejestrowaniem świata. Percepcja to weryfikowanie hipotez o nim.</p>
    <p>Nagle samochód przed Tobą zaczyna hamować. Automatycznie reagujesz. Wciskasz hamulec, odbijasz kierownicę, w międzyczasie zerkając w lusterko, czy pas obok jest wolny. Samochód przed Tobą zachował się niespodziewanie - zaskoczył Cię.</p>
    <p>Załóżmy, że samochód przed Tobą to było BMW. Po kilku tygodniach sytuacja się powtarza. Kolejne BMW zaskakuje Cię na drodze i nagle zmienia pas, zajeżdżając Ci drogę. Po kilku tygodniach samochód za Tobą miga Ci długimi po oczach, znów BMW! Zaczynasz spodziewać się nieprzewidywalnych rzeczy, gdy spotykasz samochody tej marki na drodze. Wcześniejsze sytuacje dotrenowały Twoje sieci mózgowe.</p>
    <p>Błędy predykcyjne to niespodziewane informacje, które wędrują w górę (bottom-up) i kształtują sieci tak, aby w przyszłości te informacje były już spodziewane (top-down). Cała historia ewolucyjna, kulturowa i indywidualna kształtuje architekturę sieci neuronowych. <span class="s2" data-session="2">Ale czy budujesz swój świat sam? Lev Vygotsky dodałby: inna osoba jest źródłem skalibrowanych błędów predykcyjnych dla Twojego mózgu. Nie losowych. Dopasowanych do Twojego poziomu. W Twoim Genesis ktoś stoi obok i podpowiada, co nazywać.</span></p>

    <p class="s2" data-session="2"><strong>Strefa najbliższego rozwoju (ZPD)</strong> to przestrzeń między tym, co potrafisz sam, a tym, co potrafisz z pomocą. W języku predykcyjnym: przestrzeń między modelami, które Twoje sieci już zbudowały, a modelami, które mogą zbudować przy odpowiednich błędach predykcyjnych dostarczonych z zewnątrz.</p>
    <p class="s2" data-session="2"><strong>Scaffolding</strong> to rusztowanie: struktura wsparcia, która stopniowo się wycofuje w miarę jak Twój model się kalibruje. Na początku duże wsparcie, duże błędy predykcyjne. Na końcu: sam budujesz predykcje. Rusztowanie znika, bo Twoje sieci przejęły jego funkcję.</p>
    <p class="s2" data-session="2"><strong>MKO</strong> (More Knowledgeable Other) to osoba z lepiej skalibrowanymi modelami. Nie musi być nauczycielem. Może być rówieśnikiem, rodzicem, a nawet technologią. Kluczem jest to, że MKO generuje błędy predykcyjne we właściwej strefie: nie za łatwe (brak uczenia) i nie za trudne (brak integracji).</p>
    <p class="s2" data-session="2">Piaget opisuje silnik: Ty budujesz modele. Vygotsky opisuje kalibrację: kto dostarcza Ci odpowiednie błędy. Oba mechanizmy działają jednocześnie. Pytanie nie brzmi "kto ma rację?" Pytanie brzmi: ile z Twojego modelu świata zbudowałeś sam, a ile ktoś Ci skalibrował?</p>
    <p class="s2" data-session="2"><em>Ten kurs sam w sobie jest eksperymentem Vygotskiańskim. Przychodzisz na konsultacje przed prezentacją. To jest scaffolding. Piaget powiedziałby: odkryjcie sami.</em></p>

    <hr class="section-divider" />

    <h3>Informacja</h3>
    <p>Skąd sieci mózgowe czerpią materiał do tych hipotez? Z trzech źródeł.</p>
    <ul>
      <li><strong>Eksterocepcja:</strong> wzrok, słuch, węch, smak, dotyk - sygnały o tym, co dzieje się na granicy ciała i świata.</li>
      <li><strong>Propriocepcja:</strong> pozycja kończyn, napięcie mięśni, przyspieszenie liniowe i kątowe (z układu przedsionkowego) - sygnały o tym, jak ciało porusza się w przestrzeni.</li>
      <li><strong>Interocepcja:</strong> bicie serca, oddech, głód, temperatura narządów - sygnały o stanie wnętrza ciała.</li>
    </ul>

