---
import Base from '../layouts/Base.astro';
import PasswordGate from '../components/PasswordGate.astro';

const HASH = "f4af56884306e3a5bc827f87770f843ec80be636fba15386e940a64d99d29a63";
---
<Base title="Wstęp do kognitywistyki II - kogni.pl" activePage="kursy">

<style is:global>
  .course-page { max-width: 720px; margin: 0 auto; padding: 48px 24px 80px; }

  .back-link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.3s;
  }
  .back-link:hover { color: var(--warm-glow); }

  .course-page h1 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: 2px;
    margin-bottom: 8px;
    text-align: center;
  }
  .course-page .meta {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    text-align: center;
    letter-spacing: 1px;
    margin-bottom: 48px;
  }

  .session-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--warm-glow);
    border: 1px solid var(--warm-glow);
    padding: 4px 12px;
    margin-bottom: 20px;
  }
  .session-header { text-align: center; margin-bottom: 48px; }
  .session-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: 1px;
    margin-bottom: 8px;
    margin-top: 12px;
  }
  .session-subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .course-page h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 48px 0 16px;
    letter-spacing: 0.5px;
  }
  .course-page h3 {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 32px 0 12px;
    letter-spacing: 0.3px;
  }

  .course-page p {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.85;
    margin-bottom: 16px;
  }
  .course-page strong { font-weight: 500; color: var(--text-primary); }
  .course-page em { font-style: italic; }
  .course-page ul { padding-left: 20px; margin: 12px 0 16px; }
  .course-page li {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 8px;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 40px 0;
  }

  /* ── Formula box (centered, prominent) ── */
  .formula-box {
    background: var(--warm-glow-soft);
    border: 1px solid var(--border-warm);
    padding: 20px 28px;
    margin: 28px auto;
    text-align: center;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 1px;
    max-width: 420px;
  }

  /* ── Network cascade ── */
  .network-cascade { margin: 20px 0 28px; }
  .cascade-step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .cascade-step:last-child { border-bottom: none; }
  .cascade-num {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--warm-glow);
    min-width: 32px;
    padding-top: 2px;
    flex-shrink: 0;
  }
  .cascade-content { flex: 1; }
  .cascade-name {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 3px;
  }
  .cascade-abbr {
    font-weight: 300;
    color: var(--text-dim);
    font-size: 11px;
    letter-spacing: 0.5px;
    margin-left: 6px;
  }
  .cascade-desc {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── Niche cards ── */
  .niche-cards { display: flex; flex-direction: column; gap: 10px; margin: 20px 0 24px; }
  .niche-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--warm-glow);
    padding: 14px 18px;
  }
  .niche-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--warm-glow);
    margin-bottom: 5px;
  }
  .niche-card p {
    font-size: 13px;
    margin-bottom: 0;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .niche-card strong { font-weight: 500; color: var(--text-primary); }

  /* ── Debate columns ── */
  .debate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 20px 0 24px;
  }
  @media (max-width: 560px) { .debate-grid { grid-template-columns: 1fr; } }
  .debate-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    padding: 18px;
  }
  .debate-card.continuity { border-top: 2px solid var(--warm-glow); }
  .debate-card.uniqueness { border-top: 2px solid rgba(150, 150, 210, 0.5); }
  .debate-side {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 4px;
  }
  .debate-author {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 12px;
    line-height: 1.4;
  }
  .debate-card ul { padding-left: 14px; margin: 0; }
  .debate-card li {
    font-size: 13px;
    line-height: 1.65;
    margin-bottom: 7px;
    color: var(--text-secondary);
  }
  .debate-card p { font-size: 13px; margin-bottom: 0; line-height: 1.7; color: var(--text-secondary); }
  .debate-card strong { font-weight: 500; color: var(--text-primary); }

  /* ── Language tracts ── */
  .tract-list { margin: 16px 0 20px; }
  .tract-row {
    display: flex;
    gap: 12px;
    align-items: baseline;
    padding: 9px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .tract-row:last-child { border-bottom: none; }
  .tract-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--warm-glow);
    min-width: 88px;
    flex-shrink: 0;
  }
  .tract-path {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-secondary);
    letter-spacing: 0.2px;
  }
  .tract-path .arrow { color: var(--text-dim); margin: 0 3px; }

  /* ── Figure ── */
  .figure-block {
    margin: 28px 0 32px;
    border: 1px solid var(--border-subtle);
    background: var(--bg-card);
    padding: 16px;
  }
  .figure-block img {
    width: 100%;
    display: block;
  }
  .figure-block figcaption {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    line-height: 1.6;
    margin-top: 10px;
    font-style: italic;
  }

  /* ── Table ── */
  .course-page table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-family: var(--font-body);
    font-size: 13px;
  }
  .course-page th {
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 11px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-warm);
    text-align: left;
  }
  .course-page td {
    padding: 10px 14px;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
    line-height: 1.6;
  }
  .course-page tr:last-child td { border-bottom: none; }
  .level-tag {
    font-size: 11px;
    font-weight: 500;
    color: var(--warm-glow);
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  /* ── Single video ── */
  .video-block { margin: 36px 0; }
  .video-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .video-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: rgba(0,0,0,0.3);
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
  }
  .video-caption {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    margin-top: 8px;
    font-style: italic;
  }

  /* ── YouTube lazy facade ── */
  .yt-facade {
    position: absolute;
    inset: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
  }
  .yt-facade img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.82;
    transition: opacity 0.2s;
  }
  .yt-facade:hover img { opacity: 1; }
  .yt-play-btn {
    position: relative;
    z-index: 1;
    width: 64px;
    height: 44px;
    background: rgba(198, 28, 28, 0.88);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.2s;
  }
  .yt-facade:hover .yt-play-btn {
    background: #c00;
    transform: scale(1.08);
  }
  .yt-play-btn svg { fill: #fff; width: 22px; height: 22px; }
  .video-wrapper.playing {
    box-shadow: 0 0 0 1px var(--warm-glow);
  }

  /* ── Video grid (senses) ── */
  .video-grid-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 32px 0 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .video-grid-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }
  .video-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 8px; }
  .video-grid-item { display: block; }
  .video-grid-solo { max-width: 50%; margin: 12px 0 0; }
  @media (max-width: 560px) {
    .video-grid { grid-template-columns: 1fr; }
    .video-grid-solo { max-width: 100%; }
  }

  /* ── Questions ── */
  .question-list { margin: 0; padding: 0; list-style: none; }
  .question-list li {
    display: flex;
    gap: 20px;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.65;
  }
  .question-list li:first-child { border-top: 1px solid var(--border-subtle); }
  .question-num {
    font-size: 11px;
    font-weight: 500;
    color: var(--warm-glow);
    letter-spacing: 1px;
    min-width: 24px;
    flex-shrink: 0;
    padding-top: 1px;
  }

  /* ── Bibliography ── */
  .bibliography { margin-top: 48px; }
  .bib-item {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 12px;
    padding-left: 20px;
    text-indent: -20px;
  }
  .bib-item a {
    color: var(--warm-glow);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .bib-item a:hover { opacity: 1; }
  .bib-item em { font-style: italic; }

  /* ── Act navigation ── */
  .act-nav {
    display: flex;
    justify-content: center;
    gap: 0;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--border-subtle);
    overflow-x: auto;
  }
  .act-tab {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 12px 20px 10px;
    border: none;
    background: none;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color 0.3s, border-color 0.3s;
    opacity: 0.45;
  }
  .act-tab.active {
    color: var(--warm-glow);
    border-bottom-color: var(--warm-glow);
    opacity: 1;
  }
  .act-tab.upcoming {
    cursor: default;
    opacity: 0.25;
  }
  .act-tab:not(.upcoming):hover {
    color: var(--warm-glow);
    opacity: 0.8;
  }

  /* ── Time machine slider ── */
  .time-machine {
    background: var(--bg-card);
    border-top: 1px solid var(--border-subtle);
    padding: 18px 0 14px;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg-card) 85%, transparent);
    box-shadow: 0 -2px 12px rgba(0,0,0,0.08);
    overflow: hidden;
    transform: translateZ(0);
    -webkit-transform: translateZ(0);
  }
  .time-machine-inner {
    max-width: 672px;
    margin: 0 auto;
    padding: 0 32px;
    box-sizing: border-box;
    touch-action: none;
    -ms-touch-action: none;
  }
  .tm-slider {
    width: 100%;
    max-width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    background: var(--border-subtle);
    outline: none;
    border-radius: 3px;
    cursor: pointer;
    touch-action: none;
    -ms-touch-action: none;
    box-sizing: border-box;
    display: block;
    padding: 14px 0;
    margin: -14px 0;
    background-clip: content-box;
  }
  @media (max-width: 560px) {
    .time-machine-inner {
      padding: 0 32px;
    }
  }
  .tm-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 12px;
    border-radius: 4px;
    background: var(--warm-glow);
    cursor: grab;
    border: none;
    box-shadow: 0 1px 4px rgba(0,0,0,0.3);
  }
  .tm-slider::-webkit-slider-thumb:active {
    cursor: grabbing;
    box-shadow: 0 1px 4px rgba(0,0,0,0.3), 0 0 8px rgba(200, 149, 108, 0.4);
  }
  .tm-slider::-moz-range-thumb {
    width: 20px;
    height: 12px;
    border-radius: 4px;
    background: var(--warm-glow);
    cursor: grab;
    border: none;
    box-shadow: 0 1px 4px rgba(0,0,0,0.3);
  }
  .tm-slider::-moz-range-thumb:active {
    cursor: grabbing;
    box-shadow: 0 1px 4px rgba(0,0,0,0.3), 0 0 8px rgba(200, 149, 108, 0.4);
  }
  .tm-stops {
    display: flex;
    justify-content: space-between;
    margin-top: 4px;
  }
  .tm-stop {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: var(--text-dim);
    transition: color 0.3s, font-weight 0.3s;
    padding: 4px 8px;
    border-radius: 4px;
    cursor: default;
    letter-spacing: 0.01em;
  }
  .tm-stop.active {
    color: var(--warm-glow);
    font-weight: 600;
  }
  /* ── Session additions: inline spans + standalone blocks ── */
  .s2 {
    transition: opacity 0.4s ease;
  }
  /* Block-level s2 elements */
  p.s2, li.s2 {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c8956c 30%);
  }
  p.s2 strong, li.s2 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c8956c 30%);
  }
  h3.s2 {
    color: color-mix(in srgb, var(--text-primary) 75%, #c8956c 25%);
  }
  p.s2 em {
    color: color-mix(in srgb, var(--text-dim) 70%, #c8956c 30%);
  }
  /* Inline s2 spans within existing paragraphs */
  span.s2 {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c8956c 30%);
  }
  span.s2 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c8956c 30%);
  }
  /* Legacy div.s2 support (for blocks that remain) */
  div.s2 p, div.s2 li, div.s2 .cascade-desc, div.s2 .niche-card p {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c8956c 30%);
  }
  div.s2 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c8956c 30%);
  }
  div.s2 h3 {
    color: color-mix(in srgb, var(--text-primary) 75%, #c8956c 25%);
  }
  .s2.hidden {
    display: none;
  }
  /* ── Session 3 additions (sage green tint) ── */
  .s3 {
    transition: opacity 0.4s ease;
  }
  p.s3, li.s3 {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c47a8a 30%);
  }
  p.s3 strong, li.s3 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c47a8a 30%);
  }
  h3.s3 {
    color: color-mix(in srgb, var(--text-primary) 75%, #c47a8a 25%);
  }
  p.s3 em {
    color: color-mix(in srgb, var(--text-dim) 70%, #c47a8a 30%);
  }
  span.s3 {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c47a8a 30%);
  }
  span.s3 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c47a8a 30%);
  }
  div.s3 p, div.s3 li, div.s3 .cascade-desc, div.s3 .niche-card p {
    color: color-mix(in srgb, var(--text-secondary) 70%, #c47a8a 30%);
  }
  div.s3 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #c47a8a 30%);
  }
  div.s3 h3 {
    color: color-mix(in srgb, var(--text-primary) 75%, #c47a8a 25%);
  }
  .s3.hidden {
    display: none;
  }
  /* ── Session 4 additions (muted violet tint) ── */
  .s4 {
    transition: opacity 0.4s ease;
  }
  p.s4, li.s4 {
    color: color-mix(in srgb, var(--text-secondary) 70%, #8a7ab8 30%);
  }
  p.s4 strong, li.s4 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #8a7ab8 30%);
  }
  h3.s4 {
    color: color-mix(in srgb, var(--text-primary) 75%, #8a7ab8 25%);
  }
  h2.s4 {
    color: color-mix(in srgb, var(--text-primary) 75%, #8a7ab8 25%);
  }
  p.s4 em {
    color: color-mix(in srgb, var(--text-dim) 70%, #8a7ab8 30%);
  }
  span.s4 {
    color: color-mix(in srgb, var(--text-secondary) 70%, #8a7ab8 30%);
  }
  span.s4 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #8a7ab8 30%);
  }
  div.s4 p, div.s4 li, div.s4 .cascade-desc, div.s4 .niche-card p {
    color: color-mix(in srgb, var(--text-secondary) 70%, #8a7ab8 30%);
  }
  div.s4 strong {
    color: color-mix(in srgb, var(--text-primary) 70%, #8a7ab8 30%);
  }
  div.s4 h3 {
    color: color-mix(in srgb, var(--text-primary) 75%, #8a7ab8 25%);
  }
  figure.s4 figcaption {
    color: color-mix(in srgb, var(--text-dim) 70%, #8a7ab8 30%);
  }
  .s4.hidden {
    display: none;
  }
  /* embedded S4 headings in non-emocje sections: hidden by JS but not violet */
  [data-session].hidden {
    display: none;
  }

</style>

<PasswordGate
  title="Wstęp do kognitywistyki II"
  subtitle="Semestr letni 2025/2026"
  passwordHash={HASH}
  sessionKey="wstep-2"
>
  <div class="course-page">
    <a href="/kursy" class="back-link">&larr; Kursy</a>
    <h1>Wstęp do kognitywistyki II</h1>
