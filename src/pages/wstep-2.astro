---
import Base from '../layouts/Base.astro';
import PasswordGate from '../components/PasswordGate.astro';

const HASH = "f4af56884306e3a5bc827f87770f843ec80be636fba15386e940a64d99d29a63";
---
<Base title="Wstęp do kognitywistyki II - kogni.pl" activePage="kursy">

<style is:global>
  /* ── Three-column layout ── */
  .course-layout {
    display: grid;
    grid-template-columns: 1fr minmax(0, 720px) 1fr;
    gap: 0;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 16px;
  }
  .course-page { max-width: 720px; width: 100%; min-width: 0; margin: 0 auto; padding: 48px 24px 80px; grid-column: 2; }

  /* ── Left sidebar: section navigator ── */
  .nav-sidebar {
    grid-column: 1;
    position: relative;
  }
  .nav-sidebar-inner {
    position: sticky;
    top: 120px;
    padding: 24px 12px 24px 48px;
    max-height: calc(100vh - 200px);
    overflow-y: auto;
  }
  .nav-sidebar-inner::-webkit-scrollbar { display: none; }
  .nav-sidebar-inner { scrollbar-width: none; }

  .nav-sidebar .nav-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 16px;
    padding-left: 12px;
  }
  .nav-sidebar a {
    display: block;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: var(--text-dim);
    text-decoration: none;
    padding: 6px 12px;
    border-left: 2px solid transparent;
    transition: color 0.25s, border-color 0.25s;
    line-height: 1.4;
  }
  .nav-sidebar a:hover {
    color: var(--text-secondary);
  }
  .nav-sidebar a.active {
    color: var(--text-primary);
    border-left-color: var(--warm-glow);
    font-weight: 500;
  }

  /* ── Right sidebar: glossary ── */
  .glossary-sidebar {
    grid-column: 3;
    position: relative;
  }
  .glossary-sidebar-inner {
    position: sticky;
    top: 120px;
    padding: 24px 0 24px 12px;
    max-height: calc(100vh - 200px);
    overflow-y: auto;
  }
  .glossary-sidebar-inner::-webkit-scrollbar { display: none; }
  .glossary-sidebar-inner { scrollbar-width: none; }

  .glossary-sidebar .glossary-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 16px;
    padding-left: 4px;
  }
  .glossary-entry {
    padding: 5px 4px;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--text-dim);
    transition: opacity 0.3s, max-height 0.4s;
    max-height: 60px;
    overflow: hidden;
  }
  .glossary-entry .abbr-key {
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 12px;
    letter-spacing: 0.5px;
  }
  .glossary-entry .abbr-full {
    color: var(--text-dim);
  }
  .glossary-entry.hidden {
    opacity: 0;
    max-height: 0;
    padding: 0 4px;
    overflow: hidden;
  }
  .glossary-sidebar .session-legend { margin-top: 22px; }
  .glossary-sidebar .session-legend .glossary-label { margin-bottom: 10px; }
  .session-row {
    padding: 5px 4px;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--text-dim);
  }
  .session-row .s-key {
    font-weight: 600;
    color: inherit;
    letter-spacing: 0.5px;
    margin-right: 6px;
  }

  /* ── Scroll offset for sticky header ── */
  [id^="sec-"], [id^="sub-"] {
    scroll-margin-top: 90px;
  }

  /* ── Nav subsection links ── */
  .nav-sidebar a.nav-sub {
    font-size: 12px;
    padding-left: 20px;
    color: color-mix(in srgb, var(--text-dim) 80%, transparent);
  }
  .nav-sidebar a.nav-sub:hover {
    color: var(--text-dim);
  }
  .nav-sidebar a.nav-sub.active {
    color: var(--text-secondary);
    border-left-color: color-mix(in srgb, var(--warm-glow) 50%, transparent);
    font-weight: 400;
  }

  /* ── Responsive: collapse sidebars below 1200px ── */
  @media (max-width: 1200px) {
    .course-layout {
      grid-template-columns: minmax(0, 1fr);
    }
    .nav-sidebar, .glossary-sidebar {
      display: none;
    }
    .course-page { grid-column: 1; }
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.3s;
  }
  .back-link:hover { color: var(--warm-glow); }

  .course-page h1 {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: 2px;
    margin-bottom: 8px;
    text-align: center;
  }
  .course-page .meta {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    text-align: center;
    letter-spacing: 1px;
    margin-bottom: 48px;
  }

  .session-badge {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--warm-glow);
    border: 1px solid var(--warm-glow);
    padding: 4px 12px;
    margin-bottom: 20px;
  }
  .session-header { text-align: center; margin-bottom: 48px; }
  .session-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: 1px;
    margin-bottom: 8px;
    margin-top: 12px;
  }
  .session-subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .course-page h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 48px 0 16px;
    letter-spacing: 0.5px;
  }
  .course-page h3 {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 32px 0 12px;
    letter-spacing: 0.3px;
  }

  .course-page p {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.85;
    margin-bottom: 16px;
  }
  .course-page strong { font-weight: 500; color: var(--text-primary); }
  .course-page em { font-style: italic; }
  .course-page ul { padding-left: 20px; margin: 12px 0 16px; }
  .course-page li {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 8px;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 40px 0;
  }

  /* ── Formula box (centered, prominent) ── */
  .formula-box {
    background: var(--warm-glow-soft);
    border: 1px solid var(--border-warm);
    padding: 20px 28px;
    margin: 28px auto;
    text-align: center;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 1px;
    max-width: 420px;
  }

  .frame-note {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--border-warm);
    padding: 20px 26px;
    margin: 24px 0 32px;
  }
  .frame-note .fn-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 8px;
  }
  .frame-note .fn-body {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ── Network cascade ── */
  .network-cascade { margin: 20px 0 28px; }
  .cascade-step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .cascade-step:last-child { border-bottom: none; }
  .cascade-num {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--warm-glow);
    min-width: 32px;
    padding-top: 2px;
    flex-shrink: 0;
  }
  .cascade-content { flex: 1; }
  .cascade-name {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 3px;
  }
  .cascade-abbr {
    font-weight: 300;
    color: var(--text-dim);
    font-size: 11px;
    letter-spacing: 0.5px;
    margin-left: 6px;
  }
  .cascade-desc {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── Niche cards ── */
  .niche-cards { display: flex; flex-direction: column; gap: 10px; margin: 20px 0 24px; }
  .niche-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-left: 2px solid var(--warm-glow);
    padding: 14px 18px;
  }
  .niche-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--warm-glow);
    margin-bottom: 5px;
  }
  .niche-card p {
    font-size: 13px;
    margin-bottom: 0;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .niche-card strong { font-weight: 500; color: var(--text-primary); }

  /* ── Debate columns ── */
  .debate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 20px 0 24px;
  }
  @media (max-width: 560px) { .debate-grid { grid-template-columns: 1fr; } }
  .debate-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    padding: 18px;
  }
  .debate-card.continuity { border-top: 2px solid var(--warm-glow); }
  .debate-card.uniqueness { border-top: 2px solid rgba(150, 150, 210, 0.5); }
  .debate-side {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 4px;
  }
  .debate-author {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 12px;
    line-height: 1.4;
  }
  .debate-card ul { padding-left: 14px; margin: 0; }
  .debate-card li {
    font-size: 13px;
    line-height: 1.65;
    margin-bottom: 7px;
    color: var(--text-secondary);
  }
  .debate-card p { font-size: 13px; margin-bottom: 0; line-height: 1.7; color: var(--text-secondary); }
  .debate-card strong { font-weight: 500; color: var(--text-primary); }

  /* ── Language tracts ── */
  .tract-list { margin: 16px 0 20px; }
  .tract-row {
    display: flex;
    gap: 12px;
    align-items: baseline;
    padding: 9px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .tract-row:last-child { border-bottom: none; }
  .tract-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--warm-glow);
    min-width: 88px;
    flex-shrink: 0;
  }
  .tract-path {
    min-width: 0;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-secondary);
    letter-spacing: 0.2px;
  }
  .tract-path .arrow { color: var(--text-dim); margin: 0 3px; }

  /* ── Figure ── */
  .figure-block {
    margin: 28px 0 32px;
    border: 1px solid var(--border-subtle);
    background: var(--bg-card);
    padding: 16px;
  }
  .figure-block.fig-small {
    max-width: 360px;
    margin-left: auto;
    margin-right: auto;
  }
  .figure-row {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .figure-row .figure-block {
    flex: 1 1 0;
    min-width: 0;
    max-width: none;
  }
  @media (max-width: 640px) {
    .figure-row { flex-direction: column; }
  }
  .figure-block img {
    width: 100%;
    display: block;
  }
  .figure-block figcaption {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    line-height: 1.6;
    margin-top: 10px;
    font-style: italic;
  }

  /* -- Debate grid (representationalism vs direct perception) -- */
  .debate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 24px 0 28px;
  }
  @media (max-width: 640px) { .debate-grid { grid-template-columns: 1fr; } }
  .debate-side {
    border: 1px solid var(--border-subtle);
    border-top: 2px solid var(--warm-glow);
    background: var(--bg-card);
    padding: 16px 18px;
  }
  .debate-author {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.3px;
    margin-bottom: 8px;
  }
  .debate-side p { margin: 0; font-size: 14px; }

  /* ── Table ── */
  .course-page caption {
    caption-side: top;
    text-align: left;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 12px;
    line-height: 1.4;
  }
  .course-page table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-family: var(--font-body);
    font-size: 13px;
    border: 1px solid var(--border-warm);
  }
  .course-page th {
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 11px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-warm);
    text-align: left;
  }
  .course-page td {
    padding: 10px 14px;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
    line-height: 1.6;
  }
  .course-page tr:last-child td { border-bottom: none; }
  .level-tag {
    font-size: 11px;
    font-weight: 500;
    color: var(--warm-glow);
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  /* ── Single video ── */
  .video-block { margin: 36px 0; }

  /* -- Side-by-side video: half-width thumbnail + half-width description -- */
  .video-side {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: start;
    margin: 32px 0;
  }
  .video-side .video-wrapper { margin: 0; }
  .video-side .vs-text {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-secondary);
    align-self: center;
  }
  .video-side .vs-text .vs-title {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 8px;
  }
  @media (max-width: 640px) {
    .video-side { grid-template-columns: 1fr; gap: 12px; }
  }
  .video-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .video-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: rgba(0,0,0,0.3);
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
  }
  .video-caption {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 300;
    color: var(--text-dim);
    margin-top: 8px;
    font-style: italic;
  }

  /* ── YouTube lazy facade ── */
  .yt-facade {
    position: absolute;
    inset: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
  }
  .yt-facade img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.82;
    transition: opacity 0.2s;
  }
  .yt-facade:hover img { opacity: 1; }
  .yt-play-btn {
    position: relative;
    z-index: 1;
    width: 64px;
    height: 44px;
    background: rgba(198, 28, 28, 0.88);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.2s;
  }
  .yt-facade:hover .yt-play-btn {
    background: #c00;
    transform: scale(1.08);
  }
  .yt-play-btn svg { fill: #fff; width: 22px; height: 22px; }
  .video-wrapper.playing {
    box-shadow: 0 0 0 1px var(--warm-glow);
  }

  /* ── Video grid (senses) ── */
  .video-grid-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 32px 0 14px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .video-grid-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }
  .video-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 8px; }
  .video-grid-item { display: block; }
  .video-grid-solo { max-width: 50%; margin: 12px 0 0; }
  @media (max-width: 560px) {
    .video-grid { grid-template-columns: 1fr; }
    .video-grid-solo { max-width: 100%; }
  }

  /* ── Questions ── */
  .question-list { margin: 0; padding: 0; list-style: none; }
  .question-list li {
    display: flex;
    gap: 20px;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.65;
  }
  .question-list li:first-child { border-top: 1px solid var(--border-subtle); }
  .question-num {
    font-size: 11px;
    font-weight: 500;
    color: var(--warm-glow);
    letter-spacing: 1px;
    min-width: 24px;
    flex-shrink: 0;
    padding-top: 1px;
  }

  /* ── Bibliography ── */
  .bibliography { margin-top: 48px; }
  .bib-item {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 12px;
    padding-left: 20px;
    text-indent: -20px;
  }
  .bib-item a {
    color: var(--warm-glow);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .bib-item a:hover { opacity: 1; }
  .bib-item em { font-style: italic; }

  /* ── Act navigation ── */
  .act-nav {
    display: flex;
    justify-content: center;
    gap: 0;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--border-subtle);
    overflow-x: auto;
  }
  .act-tab {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 12px 20px 10px;
    border: none;
    background: none;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color 0.3s, border-color 0.3s;
    opacity: 0.45;
  }
  .act-tab.active {
    color: var(--warm-glow);
    border-bottom-color: var(--warm-glow);
    opacity: 1;
  }
  .act-tab.upcoming {
    cursor: default;
    opacity: 0.25;
  }
  .act-tab:not(.upcoming):hover {
    color: var(--warm-glow);
    opacity: 0.8;
  }

  /* ── Time machine slider ── */
  .time-machine {
    background: var(--bg-card);
    border-top: 1px solid var(--border-subtle);
    padding: 18px 0 14px;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg-card);
    box-shadow: 0 -2px 12px rgba(0,0,0,0.3);
    overflow: hidden;
  }
  .time-machine-inner {
