<script>
  document.querySelectorAll('.question-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      const body = item.querySelector('.question-body');
      const inner = body.querySelector('.question-body-inner');
      if (item.classList.contains('open')) {
        body.style.maxHeight = '0';
        item.classList.remove('open');
      } else {
        document.querySelectorAll('.question-item.open').forEach(other => {
          other.classList.remove('open');
          other.querySelector('.question-body').style.maxHeight = '0';
        });
        body.style.maxHeight = inner.scrollHeight + 'px';
        item.classList.add('open');
      }
    });
  });
</script>

