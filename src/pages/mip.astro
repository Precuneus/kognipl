<script>
  (function () {
    const navLinks = document.querySelectorAll('.nav-sidebar a[data-nav]');
    if (!navLinks.length) return;
    const navEls = [...navLinks].map(l => document.getElementById(l.dataset.nav)).filter(Boolean);
    let current = '';
    function update() {
      const y = window.scrollY + 120;
      let active = '';
      for (const el of navEls) { if (el.offsetTop <= y) active = el.id; }
      if (active !== current) {
        current = active;
        navLinks.forEach(l => l.classList.toggle('active', l.dataset.nav === active));
      }
    }
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(() => { update(); ticking = false; }); ticking = true; }
    }, { passive: true });
    update();
  })();
</script>
