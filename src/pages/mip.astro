<script>
const DEFS = {
  "model": ["model", "Wewnętrzna reprezentacja rzeczywistości generowana przez sieci neuronowe na podstawie całej historii doświadczeń. Percepcja to nie rejestrowanie świata — to weryfikowanie predykcji modelu. Uszkodzenia mózgu pokazują, że poszczególne elementy modelu (twarze, ruch, przestrzeń lewostronna) można selektywnie wykasować."],
  "eksterocepcja": ["eksterocepcja", "Sygnały z granicy ciała i świata: wzrok, słuch, węch, smak, dotyk. Receptory eksteroreceptywne monitorują środowisko zewnętrzne i dostarczają materiału do predykcji sieci sensorycznych."],
  "propriocepcja": ["propriocepcja", "Sygnały o pozycji i ruchu ciała w przestrzeni: napięcie mięśni, kąty stawów, przyspieszenie liniowe i kątowe (układ przedsionkowy). Według Adamsa et al. — kora ruchowa wysyła predykcje właśnie o stanie proprioceptywnym, nie rozkazy skurczu mięśni."],
  "interocepcja": ["interocepcja", "Sygnały o stanie wnętrza ciała: bicie serca, oddech, głód, temperatura narządów. Powiązana z siecią istotności (VAN) i DMN — wpływa na poczucie siebie i regulację emocji."],
  "bottom-up": ["bottom-up (wstępujący)", "Przepływ informacji od receptorów ku wyższym sieciom. Niesie błędy predykcyjne — niespodziewane sygnały korygujące model. BMW zajeżdżające drogę generuje silny sygnał bottom-up, który przerywa działanie DAN i aktywuje VAN."],
  "top-down": ["top-down (zstępujący)", "Przepływ predykcji z wyższych sieci ku niższym i receptorom. Mózg aktywnie kształtuje to, czego się spodziewa — percepcja jest w dużej mierze top-down. Trening i doświadczenie wzmacniają sygnały top-down, czyniąc świat bardziej przewidywalnym."],
  "mielina": ["mielina", "Tłuszczowa osłonka owijająca aksony, produkowana przez oligodendrocyty. Przyspiesza przewodzenie sygnału elektrycznego wielokrotnie przez przewodzenie skokowe (saltatory). Istota biała mózgu to w większości zmielinizowane aksony."],
  "pacjentka-df": ["pacjentka DF", "Pacjentka z uszkodzeniem kory wzrokowej (brzuszny szlak, okolice V2/LOC) wskutek zatrucia tlenkiem węgla. Nie potrafi świadomie opisać kształtu ani orientacji obiektu, ale chwyta go z prawidłową konfiguracją dłoni. Klasyczny dowód na dysocjację szlaku grzbietowego i brzusznego (Goodale & Milner)."],
  "istota-biala": ["istota biała", "Aksony otoczone mieliną — szybkie autostrady informacji łączące odległe obszary mózgu. Biała barwa pochodzi od tłuszczowej osłonki mielinowej przyspieszającej przewodzenie sygnałów."],
  "istota-szara": ["istota szara", "Ciała komórek neuronów, dendryty i synapsy — tu odbywa się właściwe przetwarzanie. Kora mózgowa, jądra podstawy, wzgórze: wszystko zbudowane z istoty szarej."],
  "cialo-komorki": ["ciało komórki (soma)", "Centrum metaboliczne neuronu. Zawiera jądro z DNA i produkuje białka potrzebne do działania całej komórki. Sygnały z dendrytów są tu sumowane."],
  "akson": ["akson", "Pojedynczy długi wyrostek neuronu przewodzący sygnał wyjściowy (potencjał czynnościowy) w kierunku synapsy. Może mieć osłonkę mielinową, która wielokrotnie przyspiesza przewodzenie."],
  "dendryty": ["dendryty", "Rozgałęzione wyrostki neuronu zbierające sygnały wejściowe od innych neuronów. Jeden neuron może mieć tysiące dendrytów — każdy to potencjalne wejście od innej komórki."],
  "synapsy": ["synapsa", "Połączenie między neuronem a kolejną komórką. Sygnał elektryczny zamienia się tu w chemiczny (neuroprzekaźnik), przekracza szczelinę synaptyczną i znów staje się elektryczny."],
  "receptory": ["receptory", "Białka na powierzchni dendrytów wiążące neuroprzekaźniki. Różne receptory reagują na różne substancje — to właśnie tu leki psychoaktywne wywierają swój efekt."],
  "kolumny-korowe": ["kolumny korowe", "Pionowe jednostki organizacyjne kory mózgowej, ~100 neuronów przetwarzających ten sam rodzaj informacji. Kolumny orientacji w V1 reagują na kreski pod konkretnym kątem — odkrycie Hubela i Wiesela."],
  "MC": ["MC — kora ruchowa (motor cortex)", "Pierwszorzędowa kora ruchowa w zakręcie przedśrodkowym. Wysyła sygnały do rdzenia kręgowego inicjując ruchy dowolne. Organizacja somatotopiczna — mapa ciała (homunkulus ruchowy)."],
  "SSC": ["SSC — kora somatosensoryczna", "Pierwszorzędowa kora czuciowa w zakręcie zaśrodkowym. Odbiera informacje dotykowe, proprioceptywne i bólowe. Mapa ciała (homunkulus czuciowy) — usta i dłonie mają największą reprezentację."],
  "SPL": ["SPL — płacik ciemieniowy górny", "Superior parietal lobule. Część DAN. Integruje informacje o pozycji ciała w przestrzeni i kieruje ruchami oczu oraz ręki. Kluczowy dla Maravity i Irikiego — rozszerza się przy użyciu narzędzi."],
  "IPS": ["IPS — bruzda śródciemieniowa", "Intraparietal sulcus. Leży między SPL a IPL. Koduje przestrzenną lokalizację obiektów i koordynuje wzrokowo-ruchową integrację. Centralny węzeł DAN."],
  "IPL": ["IPL — płacik ciemieniowy dolny", "Inferior parietal lobule. Zawiera zakręt kątowy i nadbrzeżny. Integruje informacje z wielu zmysłów; zaangażowany w rozumienie mowy, liczenie i reprezentację ciała."],
  "FEF": ["FEF — pole czołowe oczu", "Frontal eye fields. Kontroluje dowolne ruchy oczu (sakady). Część DAN — kieruje uwagę wzrokową aktywnie, zanim jeszcze oczy się poruszą."],
  "IFJ": ["IFJ — połączenie czołowo-ciemieniowe", "Inferior frontal junction. Węzeł przełączający uwagę między zadaniami. Część DAN, ściśle współpracuje z FEF przy targetowaniu obiektów w przestrzeni."],
  "A1": ["A1 — pierwszorzędowa kora słuchowa", "Leży w zakręcie Heschla (górna część płata skroniowego). Tonotopiczna organizacja — różne częstotliwości dźwięku mapowane przestrzennie. Wejście dla przetwarzania mowy i muzyki."],
  "V1": ["V1 — pierwszorzędowa kora wzrokowa", "Leży w biegunie potylicznym. Retinotopiczna mapa pola widzenia. Uszkodzenie powoduje ślepotę korową w odpowiedniej części pola — ale pozostawia blindsight."],
  "V2": ["V2 — drugorzędowa kora wzrokowa", "Otacza V1, przetwarza dalej informacje o krawędziach, konturach i głębi. Uszkodzenie V2 (jak u pacjentki DF) zaburza świadome rozpoznawanie przy zachowanym prowadzeniu działania."],
  "preciki": ["pręciki", "Fotoreceptory siatkówki wrażliwe na światło o niskim natężeniu — widzenie zmierzchowe i peryferyczne. Jeden rodzaj pigmentu: nie rozróżniają barw, ale wykrywają ruch na obrzeżach pola widzenia."],
  "czopki": ["czopki", "Fotoreceptory skoncentrowane w dołku środkowym siatkówki. Trzy typy (S, M, L) umożliwiają widzenie barwne. Wymagają dobrego oświetlenia — stąd kolory zanikają w ciemności."],
  "szlak-grzbietowy": ["szlak grzbietowy", "\"Gdzie / jak działać\" — biegnie z V1 przez korę ciemieniową do kory ruchowej. Przetwarza przestrzenną lokalizację obiektów i prowadzi działania w czasie rzeczywistym. Zachowany u pacjentki DF."],
  "szlak-brzuszny": ["szlak brzuszny", "\"Co to jest\" — biegnie z V1 przez płat skroniowy do zakrętu wrzecionowatego. Rozpoznaje obiekty, twarze, słowa. Uszkodzony u pacjentki DF — nie może opisać obiektu, ale potrafi go chwycić."],
  "blindsight": ["blindsight (ślepowidzenie)", "Zdolność do reagowania na bodźce wzrokowe w obszarze ślepoty korowej (uszkodzenie V1) bez świadomego doznania widzenia. Dowód na działanie szlaku grzbietowego poza świadomością."],
  "okresy-krytyczne": ["okresy krytyczne", "Okna czasowe w rozwoju, gdy sieci neuronowe są szczególnie plastyczne i wrażliwe na doświadczenie. Zamknięcie jednego oka kota w tym okresie trwale reorganizuje kolumny dominacji ocznej (Hubel & Wiesel)."],
  "predykcja": ["predykcja", "Aktywne generowanie przez mózg hipotez o nadchodzących informacjach zanim do niego dotrą. Percepcja nie jest rejestrowaniem świata — jest weryfikowaniem tych hipotez. Surfer na fali, nie lustro."],
  "blad-predykcyjny": ["błąd predykcyjny", "Różnica między tym, czego sieć się spodziewała, a tym, co faktycznie nadeszło. Sygnał bottom-up korygujący model. BMW zajeżdżające drogę generuje duży błąd predykcyjny — i dotrenowuje sieć."],
  "afordancje": ["afordancje", "Możliwości do działania istniejące w relacji między organizmem a środowiskiem — nie w przedmiocie ani w świecie, lecz między nimi. Ten sam kamień: zabawka, siedzisko lub budulec zależnie od aktora i kontekstu."],
  "etologiczne-mapy": ["etologiczne mapy akcji", "Przestrzenna organizacja możliwości działania zakodowana w korze — nie mapa anatomii ciała, lecz mapa tego, co ciało może zrobić. Region obrony twarzy, region dosięgania, region manipulacji (Graziano 2016)."],
  "sieci-strukturalne": ["sieci strukturalne", "Sieci definiowane przez fizyczne połączenia aksonalne między obszarami — \"kable\" mózgu widoczne w traktografii DTI. Stabilne, zmieniają się wolno przez plastyczność."],
  "sieci-funkcjonalne": ["sieci funkcjonalne", "Sieci definiowane przez korelacje aktywności w czasie (fMRI resting-state) — obszary \"rozmawiające ze sobą\" niezależnie od tego, czy są bezpośrednio połączone. Dynamiczne, zależne od stanu."],
  "SMN": ["SMN — sieć somatomotoryczna", "Somatomotor Network. Kora ruchowa (MC) i somatosensoryczna (SSC). Koordynuje wykonywanie ruchów i odbieranie informacji czuciowych z ciała. Najściślej sprzężona z sygnałami proprioceptywnymi i dotykowymi."],
  "VIS": ["VIS — sieć wzrokowa", "Visual Network. Obustronnie obejmuje pierwszo- i drugorzędową korę wzrokową (V1, V2) oraz wyższe obszary potyliczne. Przetwarza informację wzrokową od podstawowej detekcji krawędzi po złożone rozpoznawanie obiektów."],
  "DAN": ["DAN — grzbietowa sieć uwagi", "Dorsal Attention Network. SPL, IPS, FEF, IFJ. Aktywna uwaga top-down: spodziewa się obiektów w konkretnych miejscach. Tłumi VAN podczas skupionego działania."],
  "VAN": ["VAN — brzuszna sieć uwagi", "Ventral Attention Network (Sieć istotności / SAL). Prawostronna, zawiera TPJ i korę czołową. Alarm bottom-up: przerywa DAN gdy pojawia się niespodziewany, ważny bodziec."],
  "CEN": ["CEN — sieć kontroli wykonawczej", "Central Executive Network. DLPFC i tylna kora ciemieniowa. Zarządza pamięcią roboczą, planowaniem i hamowaniem reakcji. Wkracza gdy błąd predykcyjny wymaga strategicznej odpowiedzi."],
  "DMN": ["DMN — sieć domyślna", "Default Mode Network. mPFC, PCC, zakręt kątowy, hipokamp. Aktywna w spoczynku: narracja o sobie, planowanie przyszłości, rozumienie innych. Model \"Ciebie\" — najdalej od zmysłów."],
  "pps": ["przestrzeń peripersonalna (PPS)", "Przestrzeń bezpośrednio otaczająca ciało, w której predykcje proprioceptywne mogą być weryfikowane przez kontakt fizyczny. Neurony vPMC, VIP i area 7b integrują sygnały wzrokowe, dotykowe i słuchowe z przestrzeni wokół ciała i są bezpośrednio połączone z systemem motorycznym (latencja ~10 ms). PPS rozszerza się przy użyciu narzędzi przez mechanizm Hebba (Maravita & Iriki 2004; Serino 2019)."],
  "autoshaping": ["autoshaping", "Spontaniczne dziobanie klucza CS przez gołębia w paradygmacie klasycznym — bez kontyngencji instrumentalnej. Standardowa interpretacja: sign-tracking. Reinterpretacja: autoshaping to domyślny tryb działania układu nerwowego. Warunkowanie klasyczne usuwa kontyngencję ze środowiska, nie z architektury kaskady sieciowej DMN→DAN→CEN→SMN."],
  "schemat-ciala": ["schemat ciała (body schema)", "Dynamiczny model ciała zakodowany w korze ciemieniowej (SPL, IPS). Rozszerza się na narzędzia po regularnym użyciu: neurony w polu vPMC makaka rozszerzają pola recepcyjne na całą długość grabek po kilku tygodniach treningu (Maravita & Iriki 2004). Schemat ciała to mapa predykcji proprioceptywnych, nie anatomii."],
  "warunkowanie-klasyczne": ["warunkowanie klasyczne (Pawłow)", "Paradygmat uczenia się, w którym bodziec warunkowy (CS) poprzedza bodziec bezwarunkowy (US) bez kontyngencji instrumentalnej. Działanie zwierzęcia nie wpływa na pojawienie się US. Jednak architektura sieciowa i tak generuje kaskadę predykcji prowadzącą do działania: stąd autoshaping."],
  "warunkowanie-instrumentalne": ["warunkowanie instrumentalne (Skinner)", "Paradygmat uczenia się, w którym działanie zwierzęcia determinuje pojawienie się wzmocnienia. Warunkowanie klasyczne vs. instrumentalne to rozróżnienie w projekcie eksperymentalnym, nie w architekturze mózgu. Sieć nie wie, że kontyngencja instrumentalna nie istnieje."]
};

const popover = document.getElementById('termPopover');
const popTitle = document.getElementById('termPopoverTitle');
const popBody = document.getElementById('termPopoverBody');
let active = null;

document.querySelectorAll('.term[data-key]').forEach(el => {
  el.addEventListener('click', (e) => {
    e.stopPropagation();
    const key = el.dataset.key;
    const def = DEFS[key];
    if (!def) return;

    if (active === el && popover.classList.contains('visible')) {
      popover.classList.remove('visible');
      active = null;
      return;
    }

    popTitle.textContent = def[0];
    popBody.textContent = def[1];

    const rect = el.getBoundingClientRect();
    const pw = 280;
    let left = rect.left;
    let top = rect.bottom + 8;

    if (left + pw > window.innerWidth - 12) left = window.innerWidth - pw - 12;
    if (left < 12) left = 12;
    if (top + 120 > window.innerHeight) top = rect.top - 8 - popover.offsetHeight;

    popover.style.left = left + 'px';
    popover.style.top = top + 'px';
    popover.classList.add('visible');
    active = el;
  });
});

document.addEventListener('click', () => {
  popover.classList.remove('visible');
  active = null;
});
</script>

