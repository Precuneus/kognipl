<script>
  // ─── Tab switching ───
  function showDmPanel(id) {
    document.querySelectorAll('.dm-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('panel-' + id)?.classList.add('active');
    document.querySelectorAll('.dm-tab').forEach(t => t.classList.remove('viewing'));
    document.querySelector('.dm-tab[data-panel="' + id + '"]')?.classList.add('viewing');
  }

  document.querySelectorAll('.dm-tab button[data-show]').forEach(btn => {
    btn.addEventListener('click', () => showDmPanel(btn.dataset.show));
  });

  // ─── Section gates ───
  async function sha256(message) {
    const msgBuffer = new TextEncoder().encode(message);
    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  function restoreUnlocked() {
    document.querySelectorAll('.gated-section').forEach(section => {
      const key = section.dataset.gateKey;
      if (key && sessionStorage.getItem(key) === 'open') {
        section.classList.add('unlocked');
      }
    });
    document.querySelectorAll('.section-gate').forEach(gate => {
      const targetId = gate.dataset.target;
      const target = document.getElementById(targetId);
      if (target && target.classList.contains('unlocked')) {
        gate.classList.add('unlocked');
      }
    });
  }

  function unlockSection(targetId) {
    const target = document.getElementById(targetId);
    if (!target) return;
    const key = target.dataset.gateKey;
    document.querySelectorAll('.gated-section').forEach(section => {
      if (section.dataset.gateKey === key) {
        section.classList.add('unlocked');
        if (key) sessionStorage.setItem(key, 'open');
      }
    });
    setTimeout(() => {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  }

  document.querySelectorAll('.section-gate').forEach(gate => {
    const input = gate.querySelector('.section-gate-input');
    const submit = gate.querySelector('.section-gate-submit');
    const error = gate.querySelector('.section-gate-error');
    const expectedHash = gate.dataset.hash;
    const targetId = gate.dataset.target;

    function stripDiacritics(str) {
      return str.replace(/ą/g,'a').replace(/ć/g,'c').replace(/ę/g,'e').replace(/ł/g,'l').replace(/ń/g,'n').replace(/ó/g,'o').replace(/ś/g,'s').replace(/ź/g,'z').replace(/ż/g,'z');
    }

    async function tryUnlock() {
      const password = stripDiacritics(input?.value?.trim().toLowerCase() || '');
      if (!password) return;
      const hash = await sha256(password);
      if (hash === expectedHash) {
        gate.classList.add('unlocked');
        unlockSection(targetId);
      } else {
        error?.classList.add('visible');
        input?.focus();
        setTimeout(() => error?.classList.remove('visible'), 2000);
      }
    }

    submit?.addEventListener('click', tryUnlock);
    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') tryUnlock();
    });
  });



  restoreUnlocked();
</script>

