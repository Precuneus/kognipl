---
/**
 * PasswordGate component
 * 
 * Wraps course content behind a manuscript-style password gate.
 * Uses SHA-256 hash comparison (password never stored in plaintext).
 * 
 * NOTE: This is a visual gate, not true encryption. The HTML source
 * contains the content. For real security, run StatiCrypt as a
 * post-build step: npx staticrypt dist/course.html -p "password"
 * 
 * Usage:
 *   <PasswordGate title="Wstęp II" passwordHash="abc123...">
 *     <p>Protected content here</p>
 *   </PasswordGate>
 * 
 * Generate hash: echo -n "yourpassword" | sha256sum
 */
interface Props {
  title: string;
  subtitle?: string;
  passwordHash: string;
  sessionKey?: string;
}

const { 
  title, 
  subtitle = '', 
  passwordHash,
  sessionKey = title.toLowerCase().replace(/\s+/g, '-')
} = Astro.props;
---

<style is:global>
  /* === MANUSCRIPT GATE === */
  .manuscript-gate {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: var(--bg-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  .manuscript-gate.unlocked {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .manuscript-cover {
    text-align: center;
    max-width: 400px;
    padding: 0 24px;
    animation: fadeUp 0.6s ease-out both;
  }

  /* Book cover */
  .cover-frame {
    border: 1px solid var(--border-warm);
    padding: 48px 40px 40px;
    margin-bottom: 32px;
    position: relative;
    background: linear-gradient(135deg, rgba(28, 26, 20, 0.8), rgba(14, 13, 11, 0.9));
  }

  .cover-frame::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid var(--border-subtle);
    pointer-events: none;
  }

  .cover-ornament {
    font-size: 24px;
    color: var(--warm-glow);
    opacity: 0.3;
    margin-bottom: 20px;
    letter-spacing: 8px;
  }

  .cover-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 2px;
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .cover-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .cover-line {
    width: 40px;
    height: 1px;
    background: var(--border-warm);
    margin: 0 auto 20px;
  }

  .cover-author {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  /* Password form */
  .gate-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .gate-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--text-dim);
  }

  .gate-input {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    padding: 10px 16px;
    text-align: center;
    width: 220px;
    outline: none;
    transition: border-color 0.3s;
    letter-spacing: 2px;
  }

  .gate-input:focus {
    border-color: var(--border-warm);
  }

  .gate-input::placeholder {
    color: var(--text-dim);
    font-style: italic;
    letter-spacing: 0;
  }

  .gate-submit {
    background: none;
    border: 1px solid var(--border-subtle);
    color: var(--text-dim);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 24px;
    cursor: pointer;
    transition: all 0.3s;
  }

  .gate-submit:hover {
    color: var(--warm-glow);
    border-color: rgba(232, 168, 76, 0.25);
    background: var(--warm-glow-soft);
  }

  .gate-error {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--accent-red);
    opacity: 0;
    transition: opacity 0.3s;
    height: 20px;
  }

  .gate-error.visible {
    opacity: 1;
  }

  .gate-back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    margin-top: 8px;
    padding: 6px 12px;
    transition: color 0.3s;
    cursor: pointer;
  }

  .gate-back:hover {
    color: var(--text-secondary);
  }

  /* === REVEALED CONTENT === */
  .manuscript-content {
    opacity: 0;
    transition: opacity 0.6s ease 0.3s;
  }

  .manuscript-content.visible {
    opacity: 1;
  }
</style>

<!-- Password Gate Overlay -->
<div class="manuscript-gate" id="gate" data-hash={passwordHash} data-key={sessionKey}>
  <div class="manuscript-cover">
    <div class="cover-frame">
      <div class="cover-ornament">&#10038; &#10038; &#10038;</div>
      <div class="cover-title">{title}</div>
      {subtitle && <div class="cover-subtitle">{subtitle}</div>}
      <div class="cover-line"></div>
      <div class="cover-author">Olgierd Borowiecki</div>
    </div>

    <div class="gate-form">
      <span class="gate-label">Wprowadź hasło dostępu</span>
      <input
        type="password"
        class="gate-input"
        id="gatePassword"
        placeholder="hasło"
        autocomplete="off"
      />
      <button class="gate-submit" id="gateSubmit">Otwórz</button>
      <div class="gate-error" id="gateError">Nieprawidłowe hasło</div>
      <a class="gate-back" onclick="history.back()">&larr; Wróć</a>
    </div>
  </div>
</div>

<!-- Protected Content -->
<div class="manuscript-content" id="content">
  <slot />
</div>

<script>
  const gate = document.getElementById('gate');
  const content = document.getElementById('content');
  const input = document.getElementById('gatePassword') as HTMLInputElement;
  const submit = document.getElementById('gateSubmit');
  const error = document.getElementById('gateError');
  const expectedHash = gate?.dataset.hash || '';
  const sessionKey = 'kogni-gate-' + (gate?.dataset.key || '');

  // Check if already unlocked this session
  if (sessionStorage.getItem(sessionKey) === 'open') {
    unlock();
  }

  async function sha256(message: string): Promise<string> {
    const msgBuffer = new TextEncoder().encode(message);
    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  async function tryUnlock() {
    const password = input?.value || '';
    if (!password) return;

    const hash = await sha256(password);

    if (hash === expectedHash) {
      sessionStorage.setItem(sessionKey, 'open');
      unlock();
    } else {
      error?.classList.add('visible');
      input?.focus();
      setTimeout(() => error?.classList.remove('visible'), 2000);
    }
  }

  function unlock() {
    gate?.classList.add('unlocked');
    content?.classList.add('visible');
  }

  submit?.addEventListener('click', tryUnlock);
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') tryUnlock();
  });

  // Focus input on load
  setTimeout(() => input?.focus(), 600);
</script>